{
  "name": "@atma/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./generated/client/index.ts"
  },
  "config": {
    "version": "0.1.90"
  },
  "packageManager": "bun@1.3.5",
  "scripts": {
    "start": "bun .output/server/index.mjs",
    "client:generate": "bunx nitro-client",
    "build": "bun run client:generate && nitro build",
    "dev": "nitro dev --port 10000",
